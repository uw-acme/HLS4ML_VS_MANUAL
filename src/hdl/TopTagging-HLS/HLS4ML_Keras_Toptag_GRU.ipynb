    "# Parse report\n",
    "\n",
    "Matches extract_data in handmade sweeps"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "aad9732d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "GRU-Handmade/hls4ml_prj/vivado_synth.rpt:\n",
      "  LUTs             (CLB LUTs        ) Used=   13109  Avail=1.728e+06  Util%=0.76%\n",
      "  Registers        (CLB Registers   ) Used=    3967  Avail=3.456e+06  Util%=0.11%\n",
      "  Block RAM Tile   (Block RAM Tile  ) Used=     0.5  Avail=    2688  Util%=0.02%\n",
      "  DSPs             (DSPs            ) Used=    1085  Avail=   12288  Util%=8.83%\n",
      "  Bonded IOB       (Bonded IOB      ) Used=      36  Avail=     832  Util%=4.33%\n"
     ]
    }
   ],
   "source": [
    "import re, os\n",
    "\n",
    "# Feature aliases: try newer UltraScale+ names (\"CLB ...\") first, fall back to 7-series (\"Slice ...\").\n",
    "FEATURE_ALIASES = {\n",
    "    \"LUTs\":            (\"CLB LUTs\", \"Slice LUTs\"),\n",
    "    \"Registers\":       (\"CLB Registers\", \"Slice Registers\"),\n",
    "    \"Block RAM Tile\":  (\"Block RAM Tile\",),\n",
    "    \"DSPs\":            (\"DSPs\",),\n",
    "    \"Bonded IOB\":      (\"Bonded IOB\",),\n",
    "}\n",
    "\n",
    "def _row_pat(name):\n",
    "    # Row: | <name>[*] | <used> | <fixed> | <available> | <util%> |\n",
    "    return re.escape(name) + r\"\\*?\\s*\\|\\s*([\\d.]+)\\s*\\|\\s*([\\d.]+)\\s*\\|\\s*([\\d.]+)\\s*\\|\\s*([\\d.]+)\\s*\\|\"\n",
    "\n",
    "def parse_vivado_synth(filepath, features=FEATURE_ALIASES):\n",
    "    \"\"\"Extract (Used, Util%) for each feature from a Vivado utilization report.\n",
    "\n",
    "    Works for both 7-series ('Slice LUTs') and UltraScale+ ('CLB LUTs') reports.\n",
    "    \"\"\"\n",
    "    with open(filepath) as f:\n",
    "        text = f.read()\n",
    "    out = {}\n",
    "    for label, aliases in features.items():\n",
    "        hit = None\n",
    "        for alias in aliases:\n",
    "            m = re.search(_row_pat(alias), text)\n",
    "            if m:\n",
    "                hit = {\n",
    "                    \"Row\":        alias,\n",
    "                    \"Used\":       float(m.group(1)),\n",
    "                    \"Available\":  float(m.group(3)),\n",
    "                    \"Util%\":      float(m.group(4)),\n",
    "                }\n",
    "                break\n",
    "        out[label] = hit\n",
    "    return out\n",
    "\n",
    "rpt = \"GRU-Handmade/hls4ml_prj/vivado_synth.rpt\"\n",
    "if os.path.exists(rpt):\n",
    "    results = parse_vivado_synth(rpt)\n",
    "    print(f\"{rpt}:\")\n",
    "    for label, vals in results.items():\n",
    "        if vals is None:\n",
    "            print(f\"  {label}: NOT FOUND\")\n",
    "        else:\n",
    "            print(f\"  {label:<16} ({vals['Row']:<16}) Used={vals['Used']:>8g}  Avail={vals['Available']:>8g}  Util%={vals['Util%']}%\")\n",
    "else:\n",
    "    print(rpt, \"-> NOT FOUND\")\n"
   ]
  }
